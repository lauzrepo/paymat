# Backend Environment Variables
# Copy this file to backend/.env and fill in your actual values

# ============================================
# Application Configuration
# ============================================
NODE_ENV=development
PORT=5000

# ============================================
# Database Configuration
# ============================================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/payment_portal

# ============================================
# JWT Authentication
# ============================================
# Generate strong secrets using: openssl rand -hex 32
JWT_SECRET=your-jwt-secret-here-generate-a-strong-random-string
JWT_REFRESH_SECRET=your-jwt-refresh-secret-here-generate-another-strong-string

# Token expiration times
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d

# ============================================
# Helcim Payment Gateway
# ============================================
# Get these from your Helcim dashboard
HELCIM_API_TOKEN=your-helcim-api-token
HELCIM_WEBHOOK_SECRET=your-helcim-webhook-secret
HELCIM_API_BASE_URL=https://api.helcim.com/v2

# ============================================
# Frontend Configuration
# ============================================
FRONTEND_URL=http://localhost:3000

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================
# Email Service
# ============================================
# Choose one: SendGrid or AWS SES

# SendGrid
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=your-sendgrid-api-key
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=Payment Portal

# AWS SES (alternative)
# EMAIL_PROVIDER=ses
# AWS_SES_REGION=us-east-1
# AWS_SES_ACCESS_KEY=your-aws-access-key
# AWS_SES_SECRET_KEY=your-aws-secret-key

# ============================================
# AWS S3 (Invoice PDF Storage)
# ============================================
AWS_S3_BUCKET=your-s3-bucket-name
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1

# ============================================
# Redis (Optional - for caching)
# ============================================
# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=
# REDIS_TLS_ENABLED=false

# ============================================
# Logging & Monitoring
# ============================================
LOG_LEVEL=info

# Sentry for error tracking (optional)
# SENTRY_DSN=your-sentry-dsn
# SENTRY_ENVIRONMENT=development

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Auth rate limiting (stricter)
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_ATTEMPTS=5

# Payment rate limiting (very strict)
PAYMENT_RATE_LIMIT_WINDOW_MS=60000
PAYMENT_RATE_LIMIT_MAX_ATTEMPTS=3

# ============================================
# Security
# ============================================
# Bcrypt rounds (10-12 recommended)
BCRYPT_ROUNDS=10

# Cookie settings
COOKIE_SECRET=your-cookie-secret-here
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# ============================================
# Feature Flags
# ============================================
ENABLE_GDPR_FEATURES=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_AUDIT_LOGGING=true
ENABLE_SUBSCRIPTION_MANAGEMENT=true
ENABLE_INVOICE_GENERATION=true

# ============================================
# Development Tools
# ============================================
# Enable API documentation
ENABLE_API_DOCS=true

# Enable detailed error messages (dev only!)
ENABLE_DETAILED_ERRORS=true

# Database query logging
ENABLE_QUERY_LOGGING=false

# ============================================
# Payment Configuration
# ============================================
# Default currency
DEFAULT_CURRENCY=USD

# Maximum payment amount (in cents/smallest unit)
MAX_PAYMENT_AMOUNT=10000000

# Minimum payment amount (in cents/smallest unit)
MIN_PAYMENT_AMOUNT=100

# Supported currencies (comma-separated)
SUPPORTED_CURRENCIES=USD,CAD,EUR,GBP

# ============================================
# Subscription Plans Configuration
# ============================================
# Define your subscription plans (or load from database)
# This is just for reference - actual plans should be in the database

# ============================================
# Webhook Configuration
# ============================================
WEBHOOK_TIMEOUT=30000
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_RETRY_DELAY=5000

# ============================================
# File Upload Configuration
# ============================================
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=application/pdf,image/jpeg,image/png

# ============================================
# Timezone
# ============================================
TZ=America/New_York

# ============================================
# Notes
# ============================================
# 1. NEVER commit the actual .env file to version control
# 2. Generate strong random secrets for JWT tokens
# 3. Use different secrets for development and production
# 4. Rotate secrets regularly in production
# 5. Keep your Helcim API token secure and never expose it
# 6. Use environment-specific values for production

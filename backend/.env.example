NODE_ENV=production
PORT=5000

# PostgreSQL — Railway injects this automatically as DATABASE_URL
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Generate with: openssl rand -hex 32
JWT_SECRET=replace_with_random_secret
JWT_REFRESH_SECRET=replace_with_different_random_secret
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d

# Helcim (leave as stub until you have real credentials)
HELCIM_API_TOKEN=stub
HELCIM_WEBHOOK_SECRET=stub
HELCIM_API_BASE_URL=https://api.helcim.com/v2

# Your Vercel frontend URL (no trailing slash)
FRONTEND_URL=https://app.cliqpaymat.app
ALLOWED_ORIGINS=https://app.cliqpaymat.app,https://admin.cliqpaymat.app,https://portal.cliqpaymat.app

BCRYPT_ROUNDS=10
LOG_LEVEL=info
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Resend (email)
RESEND_API_KEY=re_xxxxxxxxxxxx
SUPER_ADMIN_EMAIL=you@example.com
APP_URL=https://app.cliqpaymat.app
